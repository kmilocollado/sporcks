

{% liquid
  assign max_items = section.settings.max_products
%}

<div class="section-background color-{{ section.settings.color_scheme }}"></div>
<div
  data-testid="product-list"
  class="
    section section-{{ section.id }}
    section--{{ section.settings.section_width }}
    color-{{ section.settings.color_scheme }}
    section-resource-list
    spacing-style
    gap-style
  "
  style="
    {% render 'spacing-style', settings: section.settings %}
    {% render 'gap-style', value: section.settings.gap %}
  "
>
  {%- if section.settings.layout_type == 'carousel' -%}
    <div class="product-list-carousel-header">
      <div class="product-list-carousel-header__title">
        {%- if section.settings.title != blank -%}
          <div
            class="product-list__title text-block {{ section.settings.title_type_preset }}"
            style="{% render 'typography-style', settings: section.settings, preset: section.settings.title_type_preset %} --text-align: {{ section.settings.title_alignment }};"
          >
            {{ section.settings.title }}
          </div>
        {%- endif -%}
      </div>
      {%- if section.settings.show_view_all_link and section.settings.collection != blank -%}
        <a href="{{ section.settings.collection.url }}" class="product-list__view-all link product-list-carousel-header__view-all">
          {{ 'actions.view_all' | t }}
        </a>
      {%- endif -%}
      <div
        class="product-list-carousel-nav-slot product-list-carousel-header__nav"
        data-carousel-nav-slot="productList"
        aria-hidden="true"
      ></div>
    </div>
  {%- else -%}
    <div class="product-list-header-row">
      {%- if section.settings.title != blank -%}
        <div
          class="product-list__title text-block {{ section.settings.title_type_preset }}"
          style="{% render 'typography-style', settings: section.settings, preset: section.settings.title_type_preset %} --text-align: {{ section.settings.title_alignment }};"
        >
          {{ section.settings.title }}
        </div>
      {%- endif -%}
      {%- if section.settings.show_view_all_link and section.settings.collection != blank -%}
        <a href="{{ section.settings.collection.url }}" class="product-list__view-all link">
          {{ 'actions.view_all' | t }}
        </a>
      {%- endif -%}
    </div>
  {%- endif -%}
  <div class="section-resource-list__header">
    {%- content_for 'block', type: '_product-list-content', id: 'static-header' -%}
  </div>

  {% capture list_items %}
    {% if section.settings.collection != blank and shop.products_count != 0 %}
      {% paginate section.settings.collection.products by max_items %}
        {% for product in section.settings.collection.products limit: max_items %}
          <div
            class="resource-list__item"
          >
            {% # theme-check-disable UniqueStaticBlockId %}
              {% content_for 'block', type: '_product-card', id: 'static-product-card', closest.product: product %}
            {% # theme-check-enable UniqueStaticBlockId %}
          </div>

          {% unless forloop.last %}
            <!--@list/split-->
          {% endunless %}
        {% endfor %}
      {% endpaginate %}
    {% else %}
      {% for i in (1..max_items) %}
        <div
          class="resource-list__item"
        >
          {% # theme-check-disable UniqueStaticBlockId %}
            {% content_for 'block', type: '_product-card', id: 'static-product-card', closest.product: null %}
          {% # theme-check-enable UniqueStaticBlockId %}
        </div>

        {% unless forloop.last %}
          <!--@list/split-->
        {% endunless %}
      {% endfor %}
    {% endif %}
  {% endcapture %}

  {% liquid
    assign list_items_array = list_items | strip | split: '<!--@list/split-->'
    assign carousel_icons_style = section.settings.icons_style | default: 'arrow'
    assign carousel_icons_shape = section.settings.icons_shape | default: 'none'
  %}

  {% render 'resource-list',
    list_items: list_items,
    list_items_array: list_items_array,
    settings: section.settings,
    carousel_ref: 'productList',
    slide_count: max_items,
    content_type: 'products',
    test_id: 'resource-list-grid',
    carousel_icons_style: carousel_icons_style,
    carousel_icons_shape: carousel_icons_shape
  %}

  <div
    class="section-resource-list__content"
    style="--horizontal-alignment: {{ section.settings.horizontal_alignment }};"
  >
    {%- content_for 'blocks' -%}
  </div>
</div>

<style>
  .product-list-header-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
    margin-bottom: 1rem;
  }
  .product-list__view-all {
    flex-shrink: 0;
    white-space: nowrap;
  }
  .product-list-carousel-header__title {
    flex: 1;
    min-width: 0;
  }
  .product-list-carousel-header__view-all {
    flex-shrink: 0;
    white-space: nowrap;
    text-decoration: underline;
  }
  .product-list-carousel-nav-slot {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
  }
  .product-list-carousel-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    width: 100%;
    flex-wrap: wrap;
  }
  .product-list-carousel-header__title {
    flex: 1;
    min-width: 0;
  }
  .product-list-carousel-header__nav {
    flex-shrink: 0;
  }
  .section-{{ section.id }} slideshow-arrows .slideshow-control {
    opacity: 1 !important;
  }
  .section-{{ section.id }} .resource-list__carousel .slideshow-control[disabled],
  .section-{{ section.id }} .resource-list__carousel .slideshow-control[disabled]:hover {
    display: flex;
    opacity: 0.3 !important;
    pointer-events: auto;
  }
  @media screen and (min-width: 1025px) {
    .section-{{ section.id }} slideshow-arrows {
      position: relative;
      display: flex;
      justify-content: end;
      gap: 10px;
    }
    .section-{{ section.id }} .slideshow-control {
      margin: 0 !important;
    }
  }
</style>

{% if section.settings.layout_type == 'carousel' %}
  <script>
    (function() {
      function initCarouselNavSlot() {
        const section = document.querySelector('[data-testid="product-list"]')?.closest('.shopify-section');
        if (!section) return false;
        const slot = section.querySelector('[data-carousel-nav-slot="productList"]');
        if (!slot || slot.children.length > 0) return false;
        const slideshow = section.querySelector('slideshow-component[ref="productList"]');
        if (!slideshow) return false;
        const originalArrows = slideshow.querySelector('slideshow-arrows');
        if (!originalArrows) return false;

        var clone = originalArrows.cloneNode(true);
        var prevBtn = clone.querySelector('[ref="previous"], .slideshow-control--previous');
        var nextBtn = clone.querySelector('[ref="next"], .slideshow-control--next');
        if (!prevBtn || !nextBtn) return false;

        prevBtn.removeAttribute('on:click');
        nextBtn.removeAttribute('on:click');
        prevBtn.addEventListener('click', function(e) { e.preventDefault(); slideshow.previous(); syncDisabled(); });
        nextBtn.addEventListener('click', function(e) { e.preventDefault(); slideshow.next(); syncDisabled(); });

        function syncDisabled() {
          var origPrev = originalArrows.querySelector('[ref="previous"], .slideshow-control--previous');
          var origNext = originalArrows.querySelector('[ref="next"], .slideshow-control--next');
          if (origPrev) prevBtn.disabled = origPrev.disabled;
          if (origNext) nextBtn.disabled = origNext.disabled;
        }
        slot.appendChild(clone);
        slot.removeAttribute('aria-hidden');
        originalArrows.style.display = 'none';
        syncDisabled();
        var mo = new MutationObserver(syncDisabled);
        mo.observe(originalArrows, { attributes: true, attributeFilter: ['disabled'], subtree: true });
        return true;
      }
      function run() {
        var attempts = 0;
        var maxAttempts = 20;
        function tryInit() {
          if (initCarouselNavSlot()) return;
          attempts++;
          if (attempts < maxAttempts) setTimeout(tryInit, 150);
        }
        setTimeout(tryInit, 50);
      }
      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', run);
      } else {
        run();
      }
      document.addEventListener('shopify:section:load', function(ev) {
        if (ev.detail && ev.detail.sectionId && document.querySelector('.shopify-section[id="shopify-section-' + ev.detail.sectionId + '"] [data-testid="product-list"]')) {
          setTimeout(run, 0);
        }
      });
    })();
  </script>
{% endif %}

{% schema %}
{
